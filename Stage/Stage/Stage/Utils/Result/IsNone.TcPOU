<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="IsNone" Id="{45d926e7-4340-49c1-9630-09ea933bc1ee}" SpecialFunc="None">
    <Declaration><![CDATA[// TRUE when nIn = 0; copies nIn to nOut.
FUNCTION IsNone : BOOL
VAR_INPUT
    nIn : Result; // Result to test.
END_VAR
VAR_OUTPUT
    nOut : Result; // Copy of nIn.
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IsNone := nIn = 0;
nOut := nIn;]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>
