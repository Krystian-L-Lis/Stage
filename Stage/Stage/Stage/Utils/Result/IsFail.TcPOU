<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="IsFail" Id="{e05e24d8-50a3-4409-8484-8694994e4855}" SpecialFunc="None">
    <Declaration><![CDATA[// TRUE when nIn <= 0; copies nIn to nOut.
FUNCTION IsFail : BOOL
VAR_INPUT
    nIn : Result; // Result to test.
END_VAR
VAR_OUTPUT
    nOut : Result; // Copy of nIn.
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IsFail := nIn <= 0;
nOut := nIn;]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>
