<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="IsErr" Id="{52bb3ec0-2300-4aef-8f80-2640742ad572}" SpecialFunc="None">
    <Declaration><![CDATA[// TRUE when nIn < 0; copies nIn to nOut.
FUNCTION IsErr : BOOL
VAR_INPUT
    nIn : Result; // Result to test.
END_VAR
VAR_OUTPUT
    nOut : Result; // Copy of nIn.
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[IsErr := nIn < 0;
nOut := nIn;]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>
