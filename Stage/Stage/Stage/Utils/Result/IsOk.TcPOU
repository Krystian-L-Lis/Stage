<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="IsOk" Id="{a86826be-b52a-46f1-b35e-fa89d49ee7eb}" SpecialFunc="None">
    <Declaration><![CDATA[// TRUE when nIn > 0; copies nIn to nOut.
FUNCTION IsOk : BOOL
VAR_INPUT
    nIn : Result; // Result to test.
END_VAR
VAR_OUTPUT
    nOut : Result; // Copy of nIn.
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IsOk := nIn > 0;
nOut := nIn;]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>
