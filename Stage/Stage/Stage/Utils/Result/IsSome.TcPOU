<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="IsSome" Id="{8bd0ebbc-727e-4638-b872-a07d8f4548db}" SpecialFunc="None">
    <Declaration><![CDATA[// TRUE when nIn <> 0; copies nIn to nOut.
FUNCTION IsSome : BOOL
VAR_INPUT
    nIn : Result; // Result to test.
END_VAR
VAR_OUTPUT
    nOut : Result; // Copy of nIn.
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[IsSome := nIn <> 0;
nOut := nIn;]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>
